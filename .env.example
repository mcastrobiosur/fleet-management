# PostgreSQL
PGDATABASE=biosur
PGUSER=biosur
PGPASSWORD=change_me

# Redis (dejar vacío para sin contraseña)
REDIS_PASSWORD=

# JWT — generar con: openssl rand -hex 64
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me

# AWS S3 (fotos de reportes de falla)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Puerto del dashboard (default: 80)
DASHBOARD_PORT=80
