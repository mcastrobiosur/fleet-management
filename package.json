{
  "name": "biosur-fleet-management",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Digitalización y Gestión de Flota Biosur",
  "workspaces": [
    "backend",
    "mobile",
    "dashboard",
    "shared"
  ],
  "scripts": {
    "backend": "npm run --workspace=backend",
    "mobile": "npm run --workspace=mobile",
    "dashboard": "npm run --workspace=dashboard",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
